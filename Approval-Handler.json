    {
      "parameters": {
        "sendTo": "={{ $('Webhook').item.json.query.email }}",
        "subject": "Pengajuan Cuti DISETUJUI",
        "message": "=<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 550px; margin: 0 auto; padding: 25px; background-color: #ffffff; border-top: 6px solid #4CAF50; border-radius: 4px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);\">\n  <h3 style=\"color: #4CAF50; margin-top: 0;\">🎉 Pengajuan Cuti Anda Disetujui!</h3>\n  <p style=\"color: #333; font-size: 15px;\">Halo,</p>\n  <p style=\"color: #555; line-height: 1.6; font-size: 14px;\">Kabar baik, permohonan cuti yang Anda ajukan telah mendapatkan persetujuan resmi dari pihak Manager.</p>\n  \n  <div style=\"background-color: #f5f5f5; padding: 15px; border-radius: 5px; margin: 20px 0;\">\n    <p style=\"margin: 5px 0; font-size: 14px; color: #333;\"><strong>Durasi Pemotongan:</strong> {{ $('Webhook').item.json.query.days }} Hari</p>\n    <p style=\"margin: 5px 0; font-size: 14px; color: #333;\"><strong>Status Sistem:</strong> <span style=\"color: #4CAF50; font-weight: bold;\">APPROVED & SYNCED</span></p>\n  </div>\n  \n  <p style=\"color: #777; font-size: 13px; line-height: 1.4;\">*Catatan: Sisa kuota saldo cuti tahunan Anda di database Google Sheets telah diperbarui secara otomatis oleh sistem.*</p>\n  <p style=\"color: #333; font-size: 14px; margin-top: 25px;\">Salam hangat,<br><strong>HR Sistem</strong></p>\n</div>",
        "options": {}
      },
