    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<div style=\"font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; padding: 50px; background-color: #f4f6f9; min-height: 80vh; display: flex; align-items: center; justify-content: center;\">\n  <div style=\"background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); max-width: 450px; width: 100%;\">\n    <div style=\"font-size: 60px; margin-bottom: 20px;\">✅</div>\n    <h2 style=\"color: #2e7d32; margin-bottom: 10px;\">Proses Berhasil!</h2>\n    <p style=\"color: #555; line-height: 1.5; font-size: 15px;\">Pengajuan cuti karyawan telah berhasil <strong>Disetujui</strong>. Kuota saldo cuti pada database Google Sheets telah dipotong secara otomatis.</p>\n    <div style=\"margin-top: 30px; font-size: 12px; color: #aaa;\">Sistem Integrasi n8n API — HR Sistem</div>\n  </div>\n</div>",
